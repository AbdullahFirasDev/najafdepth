{
  "name": "al-omq-al-najafi",
  "version": "0.1.0",
  "private": true,
  "description": "Elite Arabic cultural publishing platform built with Next.js, Prisma, and PostgreSQL.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "nextjs",
    "arabic",
    "publishing",
    "prisma",
    "cultural-platform"
  ],
  "author": "",
  "license": "MIT",
