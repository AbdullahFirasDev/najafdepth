# Use a Supabase or Neon PostgreSQL connection string.
# In production, set DATABASE_URL in Vercel Environment Variables.
# Do not commit .env.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require&uselibpqcompat=true&connection_limit=1"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
SITE_URL="http://localhost:3000"
ENABLE_FALLBACK_DATA="false"

# Production on Vercel:
# NEXTAUTH_URL="https://najafdepth.vercel.app"
# SITE_URL="https://najafdepth.vercel.app"
# Keep ENABLE_FALLBACK_DATA="false" in production so database failures show
# clean empty/error states instead of development sample content.

NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="article-images"

MEILISEARCH_HOST=""
MEILISEARCH_ADMIN_KEY=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
AUDIT_IP_HASH_SALT="change-this-random-salt"
